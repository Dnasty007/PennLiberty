{
  "name": "penn-liberty-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "qr:generate": "node scripts/generate-rental-qrs.mjs",
    "rentals:json": "node scripts/build-rentals-json.mjs",
    "rentals:list": "node scripts/rental-cli.mjs list",
    "rentals:remove": "node scripts/rental-cli.mjs remove",
    "rentals:add": "node scripts/rental-cli.mjs add",
    "rentals:validate": "node scripts/rental-cli.mjs validate",
    "rentals:push": "node scripts/push-rentals.mjs",
    "rentals:push-photos": "node scripts/push-rental-photos.mjs",
    "rentals:stage-photos": "node scripts/stage-rental-photos.mjs",
    "rentals:publish": "node scripts/publish-rental.mjs",
    "rentals:deploy": "node scripts/rental-cli.mjs validate && node scripts/push-rentals.mjs"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.184.1",
    "@vercel/node": "^5.7.15",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "basic-ftp": "^6.0.1",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
