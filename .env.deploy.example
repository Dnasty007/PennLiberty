# Copy to .env.deploy (gitignored) — used by npm run rentals:push
GODADDY_FTP_HOST=ftp.pennlibertyre.com
# Additional FTP accounts use full login: name@yourdomain.com (see cPanel → Configure FTP Client)
GODADDY_FTP_USER=rentals-push@pennlibertyre.com
GODADDY_FTP_PASSWORD=your-ftp-password
# GODADDY_FTP_SECURE=true
# GODADDY_FTP_PORT=21
# Use / when the FTP account home is already public_html (GoDaddy default)
GODADDY_FTP_REMOTE_DIR=/
