# Groq API key for the For Owners AI chat assistant.
# Get one free at https://console.groq.com
# Set this in Vercel Project Settings -> Environment Variables for production.
# For local dev, copy this file to .env.local and fill in the value.
GROQ_API_KEY=your_groq_api_key_here

# Rentals page: “Submit application” on each card opens this URL (Buildium tenant apply link, etc.).
# Must begin with https:// — leave empty to fall back to a pre-filled email instead.
VITE_BUILDIUM_RENTAL_APPLICATION_URL=

# Geoapify API key for property address autocomplete (For Owners page).
# Free tier at https://myprojects.geoapify.com — no credit card needed.
VITE_GEOAPIFY_API_KEY=
